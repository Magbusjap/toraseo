# EditorConfig — universal coding style settings
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown — preserve trailing whitespace (used for line breaks)
[*.md]
trim_trailing_whitespace = false

# Makefiles require literal tabs
[Makefile]
indent_style = tab

# Rust uses 4-space indents (when we get to Tauri / if we choose Tauri)
[*.rs]
indent_size = 4
