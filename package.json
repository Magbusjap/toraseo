{
  "name": "toraseo",
  "version": "0.1.0-alpha",
  "private": true,
  "description": "Open-source SEO toolkit: Claude Bridge Instructions + Codex Workflow Instructions + MCP server + visual dashboard",
  "license": "Apache-2.0",
  "author": {
    "name": "Mikhail Ankudinov",
    "email": "magbusjap@gmail.com",
    "url": "https://github.com/Magbusjap"
  },
  "homepage": "https://github.com/Magbusjap/toraseo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Magbusjap/toraseo.git"
  },
  "bugs": {
    "url": "https://github.com/Magbusjap/toraseo/issues"
  },
  "keywords": [
    "seo",
    "mcp",
    "claude",
    "anthropic",
    "ai",
    "yandex",
    "google",
    "humanizer"
  ],
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "workspaces": [
    "core",
    "mcp",
    "app"
  ],
  "scripts": {
    "build": "npm run build --workspace=@toraseo/core && npm run build --workspace=@toraseo/mcp",
    "build:core": "npm run build --workspace=@toraseo/core",
    "build:mcp": "npm run build --workspace=@toraseo/mcp",
    "build:app": "npm run build --workspace=@toraseo/app",
    "dev:mcp": "npm run dev --workspace=@toraseo/mcp",
    "dev:app": "npm run dev --workspace=@toraseo/app",
    "test:mcp": "npm run test --workspace=@toraseo/mcp",
    "eval:dashboard": "node scripts/eval-lab/dashboard.mjs",
    "eval:article-text:compare": "node scripts/eval-lab/compare-article-text-reports.mjs",
    "eval:article-text:inspect": "node scripts/eval-lab/inspect-article-text-report.mjs",
    "clean": "npm run clean --workspaces --if-present"
  }
}
