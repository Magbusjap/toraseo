# ToraSEO .gitignore
# Defines what should NOT be committed to git/GitHub

# ============================================
# PRIVATE STRATEGIC DOCUMENTS — never commit
# ============================================
private/
private/eval-lab/
NOTES.private.md
TODO.private.md

# ============================================
# Operating system files
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================
# IDE and editor files
# ============================================
.idea/
*.swp
*.swo
*~
.project
.classpath
*.sublime-project
*.sublime-workspace
.obsidian/

# .vscode/ — исключаем всё личное, но коммитим проектные настройки
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# ============================================
# Node.js (for MCP server and app frontend)
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json.bak
.npm/

# ============================================
# Tauri / Rust (for app)
# ============================================
target/
*.rs.bk
Cargo.lock
src-tauri/target/
src-tauri/WixTools/

# ============================================
# Build artifacts
# ============================================
dist/
build/
out/
*.exe
*.dmg
*.deb
*.rpm
*.AppImage
*.app

# Exception: app/build/icons/ holds source icon assets used by
# electron-builder at packaging time (build.win.icon, etc.). They
# are NOT build artifacts — the name is a coincidence with the
# electron-builder convention. Without this allowlist, CI builds
# fail with “cannot find specified resource build/icons/icon.ico”
# because git checkout doesn't materialise them.
!app/build/
!app/build/icons/
!app/build/icons/**
app/build/mcp-runtime/

# Skill ZIPs are built locally for testing or generated by CI on tags.
# They should never be committed — the canonical distribution channel
# is GitHub Releases (see .github/workflows/release-skill.yml).
toraseo-skill-*.zip
/toraseo-claude-bridge-instructions-*.zip
/toraseo-codex-workflow-*.zip
/toraseo.zip

# ============================================
# Environment variables and secrets
# ============================================
.env
.env.local
.env.*.local
*.pem
*.key
secrets/
credentials.json
api-keys.json

# ============================================
# Logs
# ============================================
*.log
logs/
*.log.*
.commit-msg.txt

# ============================================
# Cache directories
# ============================================
.cache/
.parcel-cache/
.next/
.nuxt/
.svelte-kit/

# ============================================
# Test coverage
# ============================================
coverage/
.nyc_output/
*.lcov

# ============================================
# Tauri-specific
# ============================================
src-tauri/target/
src-tauri/gen/

# ============================================
# Temporary and backup files
# ============================================
*.tmp
*.temp
*.bak
*.backup
*.old
~$*

# ============================================
# Penpot exports (raw, before processing)
# ============================================
branding/_raw/
branding/_drafts/
branding/_exports/

# ============================================
# Local development overrides
# ============================================
config.local.json
config.local.js
.local/
.toraseo-bridge/
