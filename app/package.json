{
  "name": "@toraseo/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ToraSEO desktop application (Electron + React + TypeScript)",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "tsc --noEmit",
    "prepare:mcp-runtime": "npm run build --workspace=@toraseo/core && npm run build --workspace=@toraseo/mcp && node ../scripts/prepare-mcp-runtime.mjs",
    "dist": "npm run prepare:mcp-runtime && electron-vite build && electron-builder",
    "dist:win": "npm run prepare:mcp-runtime && electron-vite build && electron-builder --win",
    "dist:mac": "npm run prepare:mcp-runtime && electron-vite build && electron-builder --mac",
    "dist:linux": "npm run prepare:mcp-runtime && electron-vite build && electron-builder --linux",
    "release": "npm run prepare:mcp-runtime && electron-vite build && electron-builder --publish always"
  },
  "dependencies": {
    "@toraseo/core": "file:../core",
    "electron-log": "^5.2.4",
    "electron-updater": "^6.3.9",
    "i18next": "^23.16.5",
    "lucide-react": "^0.469.0",
    "ps-list": "^8.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-icon-builder": "^2.0.1",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "ru.bozheslav.toraseo",
    "productName": "ToraSEO",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "out/**/*",
      "package.json",
      "build/icons/**"
    ],
    "extraResources": [
      {
        "from": "build/mcp-runtime",
        "to": "mcp-runtime"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "Magbusjap",
      "repo": "toraseo",
      "releaseType": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icons/icon.ico",
      "artifactName": "ToraSEO-${version}-setup.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icons/icon.icns",
      "artifactName": "ToraSEO-${version}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icons/512x512.png",
      "artifactName": "ToraSEO-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icons/icon.ico",
      "uninstallerIcon": "build/icons/icon.ico"
    }
  }
}
